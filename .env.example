APP_ENV=production
APP_URL=https://new.devtakt.ru
APP_TIMEZONE=Asia/Yekaterinburg

# Источник новостей VK
VK_ACCESS_TOKEN=
VK_GROUP_DOMAIN=razdvatakt
VK_API_VERSION=5.199

# Старый Telegram-контур можно оставить пустым после перехода на VK
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_IP=31.31.196.25
TELEGRAM_CHANNEL_USERNAME=razdvatakt
TELEGRAM_CHANNEL_ID=

DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Пути для медиа определяются автоматически:
# файлы -> media
# URL   -> APP_URL/media

CORS_ALLOWED_ORIGINS=https://gktakt.ru,https://www.gktakt.ru
NEWS_API_DEFAULT_LIMIT=6
NEWS_API_MAX_LIMIT=24
