APP_ENV=production
APP_URL=https://new.devtakt.ru
APP_TIMEZONE=Asia/Yekaterinburg

# Новый токен от @BotFather
TELEGRAM_BOT_TOKEN=

# Придумайте длинную случайную строку, минимум 32 символа
TELEGRAM_WEBHOOK_SECRET=

# Фиксируем доставку webhook через IPv4, если у домена есть проблемная AAAA-запись
TELEGRAM_WEBHOOK_IP=31.31.196.25

TELEGRAM_CHANNEL_USERNAME=razdvatakt
# Необязательно. Заполним после первого тестового поста.
TELEGRAM_CHANNEL_ID=

DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Пути для медиа определяются автоматически:
# файлы -> media
# URL   -> APP_URL/media

CORS_ALLOWED_ORIGINS=https://gktakt.ru,https://www.gktakt.ru
NEWS_API_DEFAULT_LIMIT=6
NEWS_API_MAX_LIMIT=24
