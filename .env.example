APP_ENV=production
APP_URL=https://news.example.com
APP_TIMEZONE=Asia/Yekaterinburg

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=replace_with_a_long_random_string
TELEGRAM_CHANNEL_USERNAME=razdvatakt
# Заполним после первого тестового поста. Формат обычно: -1001234567890
TELEGRAM_CHANNEL_ID=

DB_HOST=localhost
DB_PORT=3306
DB_NAME=takt_news
DB_USER=takt_news
DB_PASSWORD=

# Абсолютный путь на сервере до каталога public/media
MEDIA_STORAGE_PATH=/var/www/takt-telegram-news/public/media
MEDIA_PUBLIC_URL=https://news.example.com/media

# Домены Tilda, которым разрешено читать API через браузер
CORS_ALLOWED_ORIGINS=https://gktakt.ru,https://www.gktakt.ru
NEWS_API_DEFAULT_LIMIT=6
NEWS_API_MAX_LIMIT=24
