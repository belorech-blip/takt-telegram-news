Options -Indexes
DirectoryIndex index.php

# Закрываем секретные и служебные файлы.
<FilesMatch "^(\.env(?:\..*)?|\.gitignore|README\.md)$">
    Require all denied
</FilesMatch>

RewriteEngine On

# Публично доступны только index.php, health.php, webhook.php, api/ и media/.
RewriteRule ^(?:\.git|\.github|src|storage|scripts|database)(?:/|$) - [F,L,NC]
